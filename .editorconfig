root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,xml,csproj,props,targets,config,sln,slnx,razor}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Basic style
indent_size = 4
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_between_query_expression_clauses = true

# Usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:warning

# File scoped namespace
csharp_style_namespace_declarations = file_scoped:warning

# Language features
csharp_prefer_braces = true:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_constructors = false:suggestion
csharp_prefer_simple_using_statement = true:suggestion
csharp_prefer_static_local_function = true:suggestion

# Nullable
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8603.severity = error
dotnet_diagnostic.CS8618.severity = error

# StyleCop relaxations (coexistence with default .NET style)
dotnet_diagnostic.SA1101.severity = none
dotnet_diagnostic.SA1200.severity = none
dotnet_diagnostic.SA1309.severity = none
dotnet_diagnostic.SA1413.severity = none
dotnet_diagnostic.SA1633.severity = none
dotnet_diagnostic.SA1516.severity = none

# CA1716: namespace conflicts with VB.NET keywords — we do not target VB
dotnet_diagnostic.CA1716.severity = none

# CA1848: LoggerMessage.Define vs extension methods — performance win is negligible for this app scale
dotnet_diagnostic.CA1848.severity = none

# CA1873: avoid expensive argument eval when log level disabled — same rationale as CA1848
dotnet_diagnostic.CA1873.severity = none

[**/Migrations/*.cs]
generated_code = true
dotnet_analyzer_diagnostic.severity = none

[tests/**/*.cs]
# Allow Test_Method_Naming_With_Underscores (xUnit convention)
dotnet_diagnostic.CA1707.severity = none
# Tests can touch many things
dotnet_diagnostic.CA1515.severity = none
# xUnit uses [CollectionDefinition] classes named *Collection
dotnet_diagnostic.CA1711.severity = none

# MediatR request + validator + handler live together in one file (by convention).
[src/PrimaNota.Application/**/*.cs]
dotnet_diagnostic.SA1402.severity = none
dotnet_diagnostic.SA1649.severity = none
