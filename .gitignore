# =============================================================================
# D.O.E. Framework — .gitignore Template: C# / .NET
# Generated: <YYYY-MM-DD>
# Base: gitignore.io/api/csharp + D.O.E. security rules
# =============================================================================

# --- Secrets and credentials (NEVER commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account.json
**/secrets/
appsettings.Development.json
appsettings.*.local.json

# --- Agent-specific files (NEVER commit) ---
CLAUDE.md
.cursorrules
.cursor/
.aider*
copilot-*

# --- OS-generated files ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- IDE and editor files ---
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- Temporary and generated files ---
tmp/
temp/
.tmp/
*.log
*.bak
*.orig

# --- C# / .NET ---
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
