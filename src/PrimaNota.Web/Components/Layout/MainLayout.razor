@inherits LayoutComponentBase
@using System.Security.Claims
@using PrimaNota.Application.Abstractions
@inject IEsercizioContext Esercizio
@inject NavigationManager Navigation

<MudThemeProvider Theme="@PrimaNotaTheme.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="0" Fixed="true" Color="Color.Primary" Dense="false" Class="pn-appbar">
                <div class="pn-brand">
                    <div class="pn-logo">P</div>
                    <span class="pn-brand-name">Prima Nota</span>
                </div>

                <div class="pn-year-toolbar ml-4">
                    <MudSelect T="int" Value="Esercizio.Anno" ValueChanged="OnYearChanged"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Dense="true" Class="pn-year-select">
                        @for (var y = DateTime.UtcNow.Year; y >= DateTime.UtcNow.Year - 10; y--)
                        {
                            var val = y;
                            <MudSelectItem T="int" Value="val">@val</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <MudSpacer />

                <MudIconButton Icon="@Icons.Material.Outlined.NotificationsNone"
                               Color="Color.Inherit"
                               Size="Size.Medium" />

                <MudMenu Label="@(context.User.Identity?.Name ?? "Utente")"
                         StartIcon="@Icons.Material.Filled.AccountCircle"
                         EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                         Variant="Variant.Text"
                         Color="Color.Inherit"
                         AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight"
                         Class="pn-profile-menu ml-2"
                         Dense="true">
                    <div class="px-4 py-2">
                        <MudText Typo="Typo.subtitle2">@(context.User.Identity?.Name)</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            @string.Join(", ", context.User.Claims
                                .Where(c => c.Type == ClaimTypes.Role)
                                .Select(c => c.Value))
                        </MudText>
                    </div>
                    <MudDivider />
                    <MudMenuItem Href="/account/cambia-password"
                                 Icon="@Icons.Material.Filled.Key">
                        Cambia password
                    </MudMenuItem>
                    <MudMenuItem Href="/account/signout"
                                 ForceLoad="true"
                                 Icon="@Icons.Material.Filled.Logout">
                        Esci
                    </MudMenuItem>
                </MudMenu>
            </MudAppBar>

            <MudDrawer @bind-Open="drawerOpen"
                       Elevation="0"
                       Fixed="true"
                       Variant="DrawerVariant.Responsive"
                       Breakpoint="Breakpoint.Md"
                       ClipMode="DrawerClipMode.Always"
                       Class="pn-drawer">
                <NavMenu />
            </MudDrawer>

            <MudMainContent Class="pn-main">
                <MudContainer MaxWidth="MaxWidth.False" Class="pn-container pa-8">
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    Si è verificato un errore imprevisto.
    <a href="." class="reload">Ricarica</a>
    <span class="dismiss">🗙</span>
</div>

<style>
    /* ============ AppBar ============ */
    .pn-appbar {
        box-shadow: none !important;
        padding: 0 1.5rem;
    }
    .pn-brand {
        display: flex;
        align-items: center;
        gap: .75rem;
        min-width: 16rem;
    }
    .pn-logo {
        width: 2rem;
        height: 2rem;
        background: #3b82f6;
        border-radius: .5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-style: italic;
        font-size: 1.25rem;
        color: #fff;
    }
    .pn-brand-name {
        font-size: 1.25rem;
        font-weight: 600;
        letter-spacing: .02em;
    }
    .pn-year-toolbar { display: flex; align-items: center; }
    .pn-year-select { width: 100px; }
    .pn-year-select .mud-input-outlined-border { border-color: rgba(255,255,255,0.3) !important; }
    .pn-year-select .mud-input-slot { color: #fff !important; }
    .pn-year-select .mud-select-input { color: #fff !important; font-weight: 600; }
    .pn-year-select .mud-input-adornment .mud-icon-default { color: rgba(255,255,255,0.7) !important; }

    .pn-profile-menu .mud-button-root {
        text-transform: none !important;
        color: #fff !important;
        font-weight: 500 !important;
        padding: .4rem .75rem !important;
        border-radius: 8px !important;
    }
    .pn-profile-menu .mud-button-root:hover {
        background: rgba(255,255,255,0.1) !important;
    }

    /* ============ Drawer ============ */
    .pn-drawer {
        border-right: 1px solid #e5e7eb !important;
    }

    /* ============ Main content ============ */
    .pn-main {
        background: #f9fafb;
    }
    .pn-container {
        position: relative;
    }
</style>

@code {
    private bool drawerOpen = true;

    private void OnYearChanged(int anno)
    {
        Esercizio.SwitchTo(anno);
        var uri = new Uri(Navigation.Uri);
        var path = uri.GetLeftPart(UriPartial.Path);
        Navigation.NavigateTo($"{path}?_y={anno}", forceLoad: true);
    }

    private static string Initials(ClaimsPrincipal user)
    {
        var name = user.Identity?.Name ?? "";
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(new[] { ' ', '.', '@' }, StringSplitOptions.RemoveEmptyEntries);
        var letters = string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
        return string.IsNullOrEmpty(letters) ? name[..1].ToUpperInvariant() : letters;
    }
}
