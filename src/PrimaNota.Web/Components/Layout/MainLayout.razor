@inherits LayoutComponentBase
@using System.Security.Claims

<MudThemeProvider Theme="@PrimaNotaTheme.Theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="0" Fixed="true" Color="Color.Primary" Dense="false" Class="pn-appbar">
                <div class="pn-brand">
                    <div class="pn-logo">P</div>
                    <span class="pn-brand-name">Prima Nota</span>
                </div>

                <MudSpacer />

                <div class="pn-search">
                    <MudTextField T="string"
                                  @bind-Value="searchText"
                                  Placeholder="Cerca..."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  AdornmentColor="Color.Default"
                                  Class="pn-search-input" />
                </div>

                <MudSpacer />

                <MudIconButton Icon="@Icons.Material.Outlined.NotificationsNone"
                               Color="Color.Inherit"
                               Size="Size.Medium" />

                <MudMenu AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight"
                         Class="ml-2"
                         Dense="true">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Inherit"
                                   DisableElevation="true"
                                   Class="pn-profile-btn">
                            <MudAvatar Size="Size.Small" Class="pn-avatar">@Initials(context.User)</MudAvatar>
                            <span class="pn-profile-name ml-2">@(context.User.Identity?.Name ?? "Utente")</span>
                            <MudIcon Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Small" Class="ml-1" />
                        </MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        <div class="px-4 py-2">
                            <MudText Typo="Typo.subtitle2">@(context.User.Identity?.Name)</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @string.Join(", ", context.User.Claims
                                    .Where(c => c.Type == ClaimTypes.Role)
                                    .Select(c => c.Value))
                            </MudText>
                        </div>
                        <MudDivider />
                        <MudMenuItem Href="/account/cambia-password"
                                     Icon="@Icons.Material.Filled.Key">
                            Cambia password
                        </MudMenuItem>
                        <MudMenuItem Href="/account/signout"
                                     ForceLoad="true"
                                     Icon="@Icons.Material.Filled.Logout">
                            Esci
                        </MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </MudAppBar>

            <MudDrawer @bind-Open="drawerOpen"
                       Elevation="0"
                       Fixed="true"
                       Variant="DrawerVariant.Responsive"
                       Breakpoint="Breakpoint.Md"
                       ClipMode="DrawerClipMode.Always"
                       Class="pn-drawer">
                <NavMenu />
            </MudDrawer>

            <MudMainContent Class="pn-main">
                <MudContainer MaxWidth="MaxWidth.False" Class="pn-container pa-8">
                    <div class="pn-year-chip">
                        Esercizio @CurrentYear
                    </div>
                    @Body
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    Si è verificato un errore imprevisto.
    <a href="." class="reload">Ricarica</a>
    <span class="dismiss">🗙</span>
</div>

<style>
    /* ============ AppBar ============ */
    .pn-appbar {
        box-shadow: none !important;
        padding: 0 1.5rem;
    }
    .pn-brand {
        display: flex;
        align-items: center;
        gap: .75rem;
        min-width: 16rem;
    }
    .pn-logo {
        width: 2rem;
        height: 2rem;
        background: #3b82f6;
        border-radius: .5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-style: italic;
        font-size: 1.25rem;
        color: #fff;
    }
    .pn-brand-name {
        font-size: 1.25rem;
        font-weight: 600;
        letter-spacing: .02em;
    }
    .pn-search {
        flex: 1;
        display: flex;
        justify-content: center;
        max-width: 42rem;
        padding: 0 1rem;
    }
    .pn-search-input {
        width: 100%;
    }
    .pn-search-input .mud-input-outlined-border { border-color: transparent !important; }
    .pn-search-input .mud-input-slot {
        background: #ffffff !important;
        border-radius: 8px !important;
    }
    .pn-search-input input { color: #111827 !important; }
    .pn-search-input .mud-input-adornment .mud-icon-default { color: #9ca3af !important; }

    .pn-profile-btn {
        text-transform: none !important;
        padding: .25rem .75rem !important;
        border-radius: 8px !important;
    }
    .pn-profile-btn:hover { background: rgba(255,255,255,0.1) !important; }
    .pn-profile-name { font-size: .875rem; font-weight: 500; color: #fff; }
    .pn-avatar {
        background: #ffffff !important;
        color: #1a1b41 !important;
        font-weight: 600;
    }

    /* ============ Drawer ============ */
    .pn-drawer {
        border-right: 1px solid #e5e7eb !important;
    }

    /* ============ Main content ============ */
    .pn-main {
        background: #f9fafb;
    }
    .pn-container {
        position: relative;
    }
    .pn-year-chip {
        position: absolute;
        right: 2rem;
        top: 2rem;
        font-size: .875rem;
        color: #6b7280;
    }
</style>

@code {
    private bool drawerOpen = true;
    private string? searchText;

    private int CurrentYear => DateTime.UtcNow.Year;

    private static string Initials(ClaimsPrincipal user)
    {
        var name = user.Identity?.Name ?? "";
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(new[] { ' ', '.', '@' }, StringSplitOptions.RemoveEmptyEntries);
        var letters = string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
        return string.IsNullOrEmpty(letters) ? name[..1].ToUpperInvariant() : letters;
    }
}
