@page "/account/cambia-password"
@attribute [Authorize]

<PageTitle>Cambia password · Prima Nota</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Cambia password</MudText>

<div class="pn-panel" style="max-width: 560px;">
    <div class="pn-panel-header">
        <MudText Typo="Typo.h6">La tua password</MudText>
    </div>

    <div class="pa-6">
        @if (PasswordChanged == "1")
        {
            <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="false">
                Password aggiornata con successo.
            </MudAlert>
        }

        @if (!string.IsNullOrEmpty(Error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="false">
                @ErrorMessage(Error)
            </MudAlert>
        }

        <form method="post" action="/Account/ChangePassword" class="pn-form">
            <input type="hidden" name="returnUrl" value="@(ReturnUrl ?? "/account/cambia-password")" />

            <label>
                <span>Password attuale</span>
                <input type="password"
                       name="currentPassword"
                       autocomplete="current-password"
                       required
                       minlength="1" />
            </label>

            <label>
                <span>Nuova password</span>
                <input type="password"
                       name="newPassword"
                       autocomplete="new-password"
                       required
                       minlength="12"
                       placeholder="min 12 caratteri, maiuscola, minuscola, cifra, simbolo" />
            </label>

            <label>
                <span>Conferma nuova password</span>
                <input type="password"
                       name="confirmPassword"
                       autocomplete="new-password"
                       required
                       minlength="12" />
            </label>

            <div class="pn-form-actions">
                <button type="submit" class="pn-btn-primary">Salva</button>
                <a class="pn-btn-secondary" href="/">Annulla</a>
            </div>
        </form>

        <p class="pn-form-help">
            Requisiti: almeno 12 caratteri, con minuscola, maiuscola, cifra e simbolo.
        </p>
    </div>
</div>

<style>
    .pn-form label { display: block; margin-bottom: 1rem; }
    .pn-form label span { display: block; font-size: .875rem; font-weight: 500; color: #374151; margin-bottom: .35rem; }
    .pn-form input[type=password] {
        width: 100%;
        padding: .6rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 1rem;
        background: #fff;
    }
    .pn-form input[type=password]:focus {
        outline: none;
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59,130,246,.15);
    }
    .pn-form-actions { display: flex; gap: .75rem; align-items: center; margin-top: 1.25rem; }
    .pn-btn-primary {
        background: #1a1b41;
        color: #fff;
        border: 0;
        padding: .6rem 1.25rem;
        border-radius: 8px;
        font-weight: 500;
        cursor: pointer;
    }
    .pn-btn-primary:hover { background: #111236; }
    .pn-btn-secondary {
        padding: .6rem 1.25rem;
        border-radius: 8px;
        text-decoration: none;
        color: #374151;
        border: 1px solid #d1d5db;
    }
    .pn-btn-secondary:hover { background: #f3f4f6; }
    .pn-form-help { color: #6b7280; font-size: .8125rem; margin-top: 1rem; }
</style>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery] public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "passwordChanged")] public string? PasswordChanged { get; set; }

    private static string ErrorMessage(string code) => code switch
    {
        "missing" => "Compila tutti i campi.",
        "mismatch" => "La nuova password e la conferma non coincidono.",
        "wrong_current" => "Password attuale errata.",
        "weak" => "La nuova password non rispetta i requisiti (min 12 caratteri, con minuscola, maiuscola, cifra e simbolo).",
        _ => "Non e stato possibile aggiornare la password.",
    };
}
