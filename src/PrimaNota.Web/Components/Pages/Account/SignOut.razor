@page "/account/signout"
@layout EmptyLayout

<PageTitle>Uscita in corso…</PageTitle>

<div class="pn-signout-shell">
    <form id="signout-form" method="post" action="/Account/Logout">
        <p>Uscita in corso…</p>
        <noscript>
            <button type="submit" class="pn-btn">Conferma uscita</button>
        </noscript>
    </form>
</div>

<script>
    (function () {
        var f = document.getElementById('signout-form');
        if (f) { f.submit(); }
    })();
</script>

<style>
    .pn-signout-shell {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: #f9fafb;
        color: #6b7280;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }
    .pn-btn {
        background: #1a1b41;
        color: #fff;
        border: 0;
        padding: .75rem 1.5rem;
        border-radius: 8px;
        cursor: pointer;
    }
</style>
