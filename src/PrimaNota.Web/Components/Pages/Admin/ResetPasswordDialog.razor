<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
            Imposta una nuova password per <strong>@Email</strong>. L'utente potrà cambiarla in seguito.
        </MudText>
        <MudTextField @bind-Value="password" Label="Nuova password" Required="true"
                      InputType="InputType.Password"
                      HelperText="Min 12 caratteri, con maiuscole, minuscole, numeri e simboli." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annulla</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Reimposta</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string? Email { get; set; }

    private string? password;

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(password))
        {
            return;
        }

        MudDialog.Close(DialogResult.Ok(password));
    }
}
