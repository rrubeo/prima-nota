@page "/aliquote-iva"
@attribute [Authorize(Policy = AuthorizationPolicies.RequireContabile)]
@using MediatR
@using PrimaNota.Application.Iva
@using PrimaNota.Domain.Iva
@inject IMediator Mediator
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<PageTitle>Aliquote IVA · Prima Nota</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Aliquote IVA</MudText>

<MudStack Row="true" Class="mb-4">
    <MudCheckBox T="bool" @bind-Value="includiNonAttive" @bind-Value:after="ReloadAsync" Label="Includi non attive" />
    <MudSpacer />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="NewAsync">
        Nuova aliquota
    </MudButton>
</MudStack>

<MudTable Items="items" Hover="true" Dense="true" Loading="loading" Striped="true">
    <HeaderContent>
        <MudTh>Codice</MudTh>
        <MudTh>Descrizione</MudTh>
        <MudTh Style="text-align: right">%</MudTh>
        <MudTh Style="text-align: right">% indetr.</MudTh>
        <MudTh>Tipo</MudTh>
        <MudTh>Natura</MudTh>
        <MudTh>Stato</MudTh>
        <MudTh Style="width: 150px;">Azioni</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><strong>@context.Codice</strong></MudTd>
        <MudTd>@context.Descrizione</MudTd>
        <MudTd Style="text-align: right">@($"{context.Percentuale:0.##}")</MudTd>
        <MudTd Style="text-align: right">@($"{context.PercentualeIndetraibile:0.##}")</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small">@context.Tipo</MudChip></MudTd>
        <MudTd>@(context.CodiceNatura ?? "—")</MudTd>
        <MudTd>
            @if (context.Attiva)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Attiva</MudChip>
            }
            else
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Non attiva</MudChip>
            }
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => EditAsync(context))" />
            <MudIconButton Icon="@(context.Attiva ? Icons.Material.Filled.Block : Icons.Material.Filled.CheckCircle)"
                           Size="Size.Small"
                           Color="@(context.Attiva ? Color.Warning : Color.Success)"
                           OnClick="@(() => ToggleAsync(context))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent><MudText>Nessuna aliquota.</MudText></NoRecordsContent>
</MudTable>

@code {
    private bool includiNonAttive;
    private bool loading;
    private IReadOnlyList<AliquotaIvaDto> items = Array.Empty<AliquotaIvaDto>();

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        loading = true;
        try
        {
            items = await Mediator.Send(new ListAliquoteIva(includiNonAttive));
        }
        finally
        {
            loading = false;
        }
    }

    private async Task NewAsync()
    {
        var result = await Dialog.ShowAsync<AliquotaIvaDialog>("Nuova aliquota", new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var outcome = await result.Result;
        if (outcome is { Canceled: false })
        {
            Snackbar.Add("Aliquota creata.", Severity.Success);
            await ReloadAsync();
        }
    }

    private async Task EditAsync(AliquotaIvaDto dto)
    {
        var p = new DialogParameters { ["Existing"] = dto };
        var result = await Dialog.ShowAsync<AliquotaIvaDialog>("Modifica aliquota", p, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var outcome = await result.Result;
        if (outcome is { Canceled: false })
        {
            Snackbar.Add("Aliquota aggiornata.", Severity.Success);
            await ReloadAsync();
        }
    }

    private async Task ToggleAsync(AliquotaIvaDto dto)
    {
        await Mediator.Send(new ToggleAliquotaIvaActivation(dto.Id, !dto.Attiva));
        Snackbar.Add(dto.Attiva ? "Aliquota disattivata." : "Aliquota riattivata.", Severity.Info);
        await ReloadAsync();
    }
}
