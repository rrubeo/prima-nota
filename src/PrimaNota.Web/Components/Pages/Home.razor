@page "/"
@attribute [Authorize]
@using System.Globalization
@using MediatR
@using PrimaNota.Application.Abstractions
@using PrimaNota.Application.Dashboard
@using PrimaNota.Application.PrimaNota
@using PrimaNota.Domain.PrimaNota
@inject IMediator Mediator
@inject IEsercizioContext Esercizio
@inject NavigationManager Navigation

<PageTitle>Dashboard · Prima Nota</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div class="pn-kpi-grid">
        <div class="pn-kpi-card">
            <div class="pn-kpi-icon pn-icon-indigo">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" />
            </div>
            <div class="pn-kpi-body">
                <div class="pn-kpi-label">Saldo totale</div>
                <div class="pn-kpi-value">
                    <span>@FormatCurrency(stats.SaldoTotale)</span>
                    @if (stats.SaldoTotale >= 0)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Class="pn-trend-up" Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Class="pn-trend-down" Size="Size.Small" />
                    }
                </div>
                <div class="pn-kpi-sub">Cassa @FormatCurrency(stats.SaldoCassa) · Banche @FormatCurrency(stats.SaldoBanche) · Carte @FormatCurrency(stats.SaldoCarte)</div>
            </div>
        </div>

        <div class="pn-kpi-card">
            <div class="pn-kpi-icon pn-icon-blue">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" />
            </div>
            <div class="pn-kpi-body">
                <div class="pn-kpi-label">Entrate del mese</div>
                <div class="pn-kpi-value">
                    <span>@FormatCurrency(stats.EntrateMeseCorrente)</span>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Class="pn-trend-up" Size="Size.Small" />
                </div>
                <div class="pn-kpi-sub">Uscite mese: @FormatCurrency(stats.UsciteMeseCorrente)</div>
            </div>
        </div>

        <div class="pn-kpi-card">
            <div class="pn-kpi-icon pn-icon-red">
                <MudIcon Icon="@Icons.Material.Outlined.Receipt" Size="Size.Large" />
            </div>
            <div class="pn-kpi-body">
                <div class="pn-kpi-label">Movimenti esercizio</div>
                <div class="pn-kpi-value">
                    <span>@stats.MovimentiYtdCount</span>
                </div>
                <div class="pn-kpi-sub">Bozze da completare: @stats.MovimentiDraftCount</div>
            </div>
        </div>
    </div>

    <div class="pn-panel">
        <div class="pn-panel-header d-flex align-center">
            <MudText Typo="Typo.h6">Movimenti recenti</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick='() => Navigation.NavigateTo("/movimenti")'>
                Vedi tutti
            </MudButton>
        </div>

        @if (recenti.Count == 0)
        {
            <div class="pn-empty-state">
                <MudIcon Icon="@Icons.Material.Outlined.Inbox" Size="Size.Large" Class="mud-text-secondary" />
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Nessun movimento registrato. Dal menu Prima Nota → Movimenti clicca "Nuovo" per iniziare.
                </MudText>
            </div>
        }
        else
        {
            <MudTable Items="recenti" Hover="true" Breakpoint="Breakpoint.Sm" Class="pn-transactions">
                <HeaderContent>
                    <MudTh>Data</MudTh>
                    <MudTh>Descrizione</MudTh>
                    <MudTh>Causale</MudTh>
                    <MudTh Style="text-align:right">Importo</MudTh>
                    <MudTh>Stato</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Data.ToString("dd/MM/yyyy", ItCulture)</MudTd>
                    <MudTd>@context.Descrizione</MudTd>
                    <MudTd>@context.CausaleNome</MudTd>
                    <MudTd Style="text-align:right; font-weight: 500;">@FormatCurrency(context.Totale)</MudTd>
                    <MudTd>
                        <span class="pn-status pn-status-@context.Stato.ToString().ToLowerInvariant()">@context.Stato</span>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </div>
}

<style>
    .pn-kpi-grid { display: grid; grid-template-columns: repeat(1, minmax(0, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
    @@media (min-width: 768px) { .pn-kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    .pn-kpi-card { background: #fff; border: 1px solid #f3f4f6; border-radius: 12px; box-shadow: 0 1px 2px rgba(0,0,0,0.04); padding: 1.25rem; display: flex; align-items: center; gap: 1rem; }
    .pn-kpi-icon { width: 3rem; height: 3rem; border-radius: 9999px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .pn-icon-indigo { background: #eef2ff; color: #6366f1; }
    .pn-icon-blue   { background: #eff6ff; color: #3b82f6; }
    .pn-icon-red    { background: #fef2f2; color: #f87171; }
    .pn-kpi-body { flex: 1; }
    .pn-kpi-label { color: #6b7280; font-size: .875rem; font-weight: 500; margin-bottom: .25rem; }
    .pn-kpi-sub   { color: #6b7280; font-size: .75rem; margin-top: .25rem; }
    .pn-kpi-value { display: flex; align-items: baseline; gap: .5rem; font-size: 1.5rem; font-weight: 700; color: #111827; }
    .pn-trend-up   { color: #10b981 !important; }
    .pn-trend-down { color: #ef4444 !important; }

    .pn-panel { background: #fff; border: 1px solid #f3f4f6; border-radius: 12px; box-shadow: 0 1px 2px rgba(0,0,0,0.04); overflow: hidden; }
    .pn-panel-header { padding: 1rem 1.5rem; border-bottom: 1px solid #f3f4f6; }
    .pn-empty-state { padding: 3rem 1.5rem; display: flex; flex-direction: column; align-items: center; gap: .75rem; text-align: center; }
    .pn-transactions .mud-table-head .mud-table-cell { background: #f9fafb !important; color: #6b7280; font-weight: 500; font-size: .875rem; }
    .pn-status { display: inline-flex; align-items: center; padding: .25rem .625rem; border-radius: 9999px; font-size: .75rem; font-weight: 500; }
    .pn-status-draft      { background: #f3f4f6; color: #374151; }
    .pn-status-confirmed  { background: #dbeafe; color: #1e40af; }
    .pn-status-reconciled { background: #d1fae5; color: #065f46; }
</style>

@code {
    private static readonly CultureInfo ItCulture = new("it-IT");

    private bool loading = true;
    private DashboardStats stats = new(0, 0, 0, 0, 0, 0, 0, 0);
    private IReadOnlyList<MovimentoListItemDto> recenti = Array.Empty<MovimentoListItemDto>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            stats = await Mediator.Send(new GetDashboardStats(Esercizio.Anno));
            var all = await Mediator.Send(new ListMovimenti(Esercizio.Anno));
            recenti = all.Take(5).ToList();
        }
        finally
        {
            loading = false;
        }
    }

    private static string FormatCurrency(decimal v) => v.ToString("N2", ItCulture) + " €";
}
