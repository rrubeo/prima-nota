@page "/"
@attribute [Authorize]
@using System.Globalization

<PageTitle>Dashboard · Prima Nota</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>

<div class="pn-kpi-grid">
    <div class="pn-kpi-card">
        <div class="pn-kpi-icon pn-icon-indigo">
            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="Size.Large" />
        </div>
        <div class="pn-kpi-body">
            <div class="pn-kpi-label">Saldo totale</div>
            <div class="pn-kpi-value">
                <span>@FormatCurrency(totalBalance)</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Class="pn-trend-up" Size="Size.Small" />
            </div>
        </div>
    </div>

    <div class="pn-kpi-card">
        <div class="pn-kpi-icon pn-icon-blue">
            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" />
        </div>
        <div class="pn-kpi-body">
            <div class="pn-kpi-label">Ricavi del mese</div>
            <div class="pn-kpi-value">
                <span>@FormatCurrency(monthlyRevenue)</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Class="pn-trend-up" Size="Size.Small" />
            </div>
        </div>
    </div>

    <div class="pn-kpi-card">
        <div class="pn-kpi-icon pn-icon-red">
            <MudIcon Icon="@Icons.Material.Outlined.Receipt" Size="Size.Large" />
        </div>
        <div class="pn-kpi-body">
            <div class="pn-kpi-label">Fatture in sospeso</div>
            <div class="pn-kpi-sub">@pendingInvoicesCount fatture</div>
            <div class="pn-kpi-value pn-kpi-negative">
                <span>@FormatCurrency(pendingInvoicesTotal)</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Class="pn-trend-down" Size="Size.Small" />
            </div>
        </div>
    </div>
</div>

<div class="pn-panel">
    <div class="pn-panel-header">
        <MudText Typo="Typo.h6">Movimenti recenti</MudText>
    </div>

    @if (recentTransactions.Count == 0)
    {
        <div class="pn-empty-state">
            <MudIcon Icon="@Icons.Material.Outlined.Inbox" Size="Size.Large" Class="mud-text-secondary" />
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                I movimenti di prima nota verranno visualizzati qui quando sara attivo il modulo 07.
            </MudText>
        </div>
    }
    else
    {
        <MudTable Items="recentTransactions" Hover="true" Breakpoint="Breakpoint.Sm" Class="pn-transactions">
            <HeaderContent>
                <MudTh>Data</MudTh>
                <MudTh>Descrizione</MudTh>
                <MudTh>Categoria</MudTh>
                <MudTh Style="text-align:right">Importo</MudTh>
                <MudTh>Stato</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Data.ToString("dd/MM/yyyy", ItCulture)</MudTd>
                <MudTd>@context.Descrizione</MudTd>
                <MudTd>@context.Categoria</MudTd>
                <MudTd Style="text-align:right; font-weight: 500;">@FormatCurrency(context.Importo)</MudTd>
                <MudTd>
                    <span class="pn-status pn-status-@context.Stato.ToLowerInvariant()">@context.Stato</span>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</div>

<style>
    .pn-kpi-grid {
        display: grid;
        grid-template-columns: repeat(1, minmax(0, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    @@media (min-width: 768px) { .pn-kpi-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }

    .pn-kpi-card {
        background: #fff;
        border: 1px solid #f3f4f6;
        border-radius: 12px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .pn-kpi-icon {
        width: 3rem;
        height: 3rem;
        border-radius: 9999px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .pn-icon-indigo { background: #eef2ff; color: #6366f1; }
    .pn-icon-blue   { background: #eff6ff; color: #3b82f6; }
    .pn-icon-red    { background: #fef2f2; color: #f87171; }

    .pn-kpi-body { flex: 1; }
    .pn-kpi-label { color: #6b7280; font-size: .875rem; font-weight: 500; margin-bottom: .25rem; }
    .pn-kpi-sub   { color: #6b7280; font-size: .75rem; margin-bottom: .25rem; }
    .pn-kpi-value {
        display: flex;
        align-items: baseline;
        gap: .5rem;
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
    }
    .pn-kpi-negative { color: #ef4444 !important; font-size: 1.125rem !important; }
    .pn-trend-up   { color: #10b981 !important; }
    .pn-trend-down { color: #ef4444 !important; }

    .pn-panel {
        background: #fff;
        border: 1px solid #f3f4f6;
        border-radius: 12px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
        overflow: hidden;
    }
    .pn-panel-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #f3f4f6;
    }
    .pn-empty-state {
        padding: 3rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .75rem;
        text-align: center;
    }

    .pn-transactions .mud-table-head .mud-table-cell {
        background: #f9fafb !important;
        color: #6b7280;
        font-weight: 500;
        font-size: .875rem;
    }

    .pn-status {
        display: inline-flex;
        align-items: center;
        padding: .25rem .625rem;
        border-radius: 9999px;
        font-size: .75rem;
        font-weight: 500;
    }
    .pn-status-completed  { background: #d1fae5; color: #065f46; }
    .pn-status-pending    { background: #fef3c7; color: #9a3412; }
    .pn-status-reconciled { background: #dbeafe; color: #1e40af; }
    .pn-status-draft      { background: #f3f4f6; color: #374151; }
</style>

@code {
    private static readonly CultureInfo ItCulture = new("it-IT");

    private decimal totalBalance;
    private decimal monthlyRevenue;
    private decimal pendingInvoicesTotal;
    private int pendingInvoicesCount;

    private record RecentTransaction(DateOnly Data, string Descrizione, string Categoria, decimal Importo, string Stato);

    private IReadOnlyList<RecentTransaction> recentTransactions = Array.Empty<RecentTransaction>();

    protected override void OnInitialized()
    {
        totalBalance = 0m;
        monthlyRevenue = 0m;
        pendingInvoicesTotal = 0m;
        pendingInvoicesCount = 0;
        recentTransactions = Array.Empty<RecentTransaction>();
    }

    private static string FormatCurrency(decimal value) =>
        "€ " + value.ToString("N2", ItCulture);
}
