@using System.Globalization
@using PrimaNota.Application.Iva

<MudTable Items="Righe"
          Hover="true"
          Dense="true"
          Loading="Loading"
          Striped="true"
          Class="mt-3 pn-registro-table"
          Breakpoint="Breakpoint.None">
    <HeaderContent>
        <MudTh Style="width:90px; white-space:nowrap">Data</MudTh>
        <MudTh Style="width:80px; white-space:nowrap">Numero</MudTh>
        <MudTh Style="width:70px; white-space:nowrap">Causale</MudTh>
        <MudTh Style="white-space:nowrap">Controparte</MudTh>
        <MudTh Style="width:120px; white-space:nowrap">P.IVA / CF</MudTh>
        <MudTh Style="white-space:nowrap">Descrizione</MudTh>
        <MudTh Style="width:100px; white-space:nowrap">Aliquota</MudTh>
        <MudTh Style="width:110px; text-align:right; white-space:nowrap">Imponibile</MudTh>
        <MudTh Style="width:100px; text-align:right; white-space:nowrap">Imposta</MudTh>
        <MudTh Style="width:110px; text-align:right; white-space:nowrap">Totale</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Data.ToString("dd/MM/yyyy", ItCulture)</MudTd>
        <MudTd>@context.Numero</MudTd>
        <MudTd>@context.CausaleCodice</MudTd>
        <MudTd>@context.AnagraficaRagioneSociale</MudTd>
        <MudTd>@(context.PartitaIva ?? context.CodiceFiscale)</MudTd>
        <MudTd>@context.Descrizione</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small">@context.AliquotaCodice @(context.AliquotaPercentuale > 0 ? $"({context.AliquotaPercentuale:0}%)" : "")</MudChip>
        </MudTd>
        <MudTd Style="text-align:right; font-family: monospace;">@FormatCurrency(context.Imponibile)</MudTd>
        <MudTd Style="text-align:right; font-family: monospace;">@FormatCurrency(context.Imposta)</MudTd>
        <MudTd Style="text-align:right; font-family: monospace; font-weight: 600;">@FormatCurrency(context.Lordo)</MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Class="pa-6 mud-text-secondary">Nessun movimento con IVA in questo periodo.</MudText>
    </NoRecordsContent>
</MudTable>

@if (Righe.Count > 0)
{
    <div class="pn-registro-totali">
        <span class="pn-registro-totali-label">Totali</span>
        <span class="pn-registro-totali-val">@FormatCurrency(Righe.Sum(r => r.Imponibile))</span>
        <span class="pn-registro-totali-val">@FormatCurrency(Righe.Sum(r => r.Imposta))</span>
        <span class="pn-registro-totali-val pn-registro-totali-bold">@FormatCurrency(Righe.Sum(r => r.Lordo))</span>
    </div>
}

<style>
    .pn-registro-table .mud-table-cell,
    .pn-registro-table .mud-table-head .mud-table-cell { font-size: 0.8125rem; padding-top: 4px; padding-bottom: 4px; }
    .pn-registro-totali {
        display: flex; justify-content: flex-end; align-items: baseline; gap: 0;
        padding: 12px 16px; border-top: 2px solid #e5e7eb; background: #f9fafb;
        font-size: 0.8125rem;
    }
    .pn-registro-totali-label { font-weight: 700; margin-right: 16px; }
    .pn-registro-totali-val { width: 110px; text-align: right; font-family: monospace; font-weight: 700; }
    .pn-registro-totali-bold { font-weight: 800; }
</style>

@code {
    private static readonly CultureInfo ItCulture = new("it-IT");

    [Parameter] public IReadOnlyList<RegistroIvaRigaDto> Righe { get; set; } = Array.Empty<RegistroIvaRigaDto>();

    [Parameter] public bool Loading { get; set; }

    private static string FormatCurrency(decimal v) => v.ToString("N2", ItCulture);
}
