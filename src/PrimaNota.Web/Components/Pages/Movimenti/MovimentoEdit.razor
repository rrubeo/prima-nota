@page "/movimenti/nuovo"
@page "/movimenti/{Id:guid}"
@attribute [Authorize(Policy = AuthorizationPolicies.RequireContabile)]
@using System.Globalization
@using MediatR
@using PrimaNota.Application.Abstractions
@using PrimaNota.Application.Anagrafiche
@using PrimaNota.Application.ContiFinanziari
@using PrimaNota.Application.Iva
@using PrimaNota.Application.PianoConti
@using PrimaNota.Application.PrimaNota
@using PrimaNota.Domain.PianoConti
@using PrimaNota.Domain.PrimaNota
@using PrimaNota.Web.Components.Pages.Anagrafiche
@inject IMediator Mediator
@inject IEsercizioContext Esercizio
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject IHttpClientFactory HttpFactory

<PageTitle>@Title · Prima Nota</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@Title</MudText>

@if (loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudPaper Class="pa-4 mb-4" Elevation="0">
        <MudGrid>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="Data registrazione"
                               Date="@DateOnlyToDate(model.Data)"
                               DateChanged="@(d => { if (d.HasValue) { model.Data = DateOnly.FromDateTime(d.Value); model.EsercizioAnno = model.Data.Year; if (model.DataCompetenza is null) model.DataCompetenza = model.Data; } })"
                               Required="true" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="Data competenza IVA"
                               Date="@DateOnlyToDate(model.DataCompetenza ?? model.Data)"
                               DateChanged="@(d => { if (d.HasValue) { model.DataCompetenza = DateOnly.FromDateTime(d.Value); } })"
                               HelperText="Per fatture XML = data documento" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudTextField @bind-Value="model.Numero" Label="Numero (fattura, ricevuta...)" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="Guid" @bind-Value="model.CausaleId" Label="Causale" Required="true"
                           ToStringFunc="@FormatCausale">
                    @foreach (var c in causali)
                    {
                        <MudSelectItem T="Guid" Value="@c.Id">@c.Codice — @c.Nome</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="9">
                <MudTextField @bind-Value="model.Descrizione" Label="Descrizione" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <AnagraficaPicker Value="model.AnagraficaId"
                                  ValueChanged="v => model.AnagraficaId = v"
                                  Anagrafiche="anagrafiche"
                                  OnNewAnagraficaCreated="OnAnagraficaCreatedAsync"
                                  Label="Anagrafica (default)"
                                  SuggestedRuolo="HeaderSuggestedRuolo"
                                  Disabled="@(!IsEditable)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="model.Note" Label="Note" Lines="2" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 mb-4" Elevation="0">
        <div class="d-flex align-center mb-3">
            <MudText Typo="Typo.h6">Righe</MudText>
            <MudSpacer />
            <MudText Typo="Typo.body2" Class="mud-text-secondary mr-3">Totale: @FormatCurrency(TotaleRighe)</MudText>
            <MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="AddRiga" Disabled="!IsEditable">Aggiungi riga</MudButton>
        </div>

        @if (model.Righe.Count == 0)
        {
            <MudAlert Severity="Severity.Info">Nessuna riga. Aggiungine almeno una.</MudAlert>
        }
        else
        {
            <MudTable Items="model.Righe" Dense="true" Hover="true" Breakpoint="Breakpoint.None">
                <HeaderContent>
                    <MudTh Style="width:130px">Importo €</MudTh>
                    <MudTh>Conto</MudTh>
                    <MudTh>Categoria</MudTh>
                    <MudTh>Anagrafica</MudTh>
                    <MudTh>Aliquota IVA</MudTh>
                    <MudTh>Note</MudTh>
                    <MudTh Style="width:50px"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd><MudNumericField T="decimal" @bind-Value="context.Importo" HideSpinButtons="true" Disabled="!IsEditable" /></MudTd>
                    <MudTd>
                        <MudSelect T="Guid" @bind-Value="context.ContoFinanziarioId" Disabled="!IsEditable"
                                   Margin="Margin.Dense" ToStringFunc="@FormatConto">
                            @foreach (var c in conti)
                            {
                                <MudSelectItem T="Guid" Value="@c.Id">@c.Codice — @c.Nome</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <MudSelect T="Guid" @bind-Value="context.CategoriaId" Disabled="!IsEditable"
                                   Margin="Margin.Dense" ToStringFunc="@FormatCategoria">
                            @foreach (var c in categorie)
                            {
                                <MudSelectItem T="Guid" Value="@c.Id">@c.Codice — @c.Nome</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <AnagraficaPicker Value="context.AnagraficaId"
                                          ValueChanged="v => context.AnagraficaId = v"
                                          Anagrafiche="anagrafiche"
                                          OnNewAnagraficaCreated="OnAnagraficaCreatedAsync"
                                          Label=""
                                          SuggestedRuolo="@RigaSuggestedRuolo(context)"
                                          Disabled="@(!IsEditable)" />
                    </MudTd>
                    <MudTd>
                        <MudSelect T="Guid?" @bind-Value="context.AliquotaIvaId" Disabled="!IsEditable"
                                   Margin="Margin.Dense" Clearable="true" ToStringFunc="@FormatAliquota">
                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">—</MudSelectItem>
                            @foreach (var a in aliquote)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)a.Id)">@a.Codice — @a.Descrizione</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd><MudTextField @bind-Value="context.Note" Margin="Margin.Dense" Disabled="!IsEditable" /></MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => RemoveRiga(context))" Disabled="!IsEditable" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>

    @if (Id.HasValue)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="0">
            <div class="d-flex align-center mb-3">
                <MudText Typo="Typo.h6">Allegati</MudText>
                <MudSpacer />
                <MudFileUpload T="IBrowserFile"
                               OnFilesChanged="OnAllegatoSelected"
                               Accept=".pdf,.png,.jpg,.jpeg,.xlsx,.csv,.xml"
                               Hidden="false"
                               MaximumFileCount="1"
                               Disabled="@(!CanAddAttachment)">
                    <ActivatorContent>
                        <MudButton HtmlTag="label"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.UploadFile"
                                   Disabled="@(!CanAddAttachment)">
                            Carica allegato
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
            </div>

            @if (allegati.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Nessun allegato.</MudText>
            }
            else
            {
                <MudList T="AllegatoDto" Dense="true">
                    @foreach (var a in allegati)
                    {
                        <MudListItem T="AllegatoDto" Icon="@Icons.Material.Filled.Description">
                            <div class="d-flex align-center w-100">
                                <MudLink Href="@($"/allegati/{a.Id}")" Target="_blank" Class="mr-2">
                                    @a.NomeFile
                                </MudLink>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @FormatFileSize(a.Size) · @a.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm", ItCulture)
                                </MudText>
                                <MudSpacer />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteAllegatoAsync(a))"
                                               Disabled="@(!CanAddAttachment)" />
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    }

    @if (Id.HasValue && stato != StatoMovimento.Reconciled)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="0">
            <div class="d-flex align-center mb-3 gap-3">
                <MudText Typo="Typo.h6">Pagamenti / incassi</MudText>
                <MudChip T="string" Size="Size.Small" Color="@(isFullyPaid ? Color.Success : Color.Warning)">
                    @(isFullyPaid
                        ? $"Saldato il {(dataPagamento?.ToString("dd/MM/yyyy") ?? "-")}"
                        : $"Residuo {FormatCurrency(residuo)}")
                </MudChip>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Totale fattura @FormatCurrency(Math.Abs(totaleLordo)) · Incassato/Pagato @FormatCurrency(totalePagato)
                </MudText>
            </div>

            <MudGrid Class="mb-2">
                <MudItem xs="12" sm="3">
                    <MudDatePicker Label="Data pagamento"
                                   Date="@DateOnlyToDate(newPagamentoData)"
                                   DateChanged="@(d => { if (d.HasValue) { newPagamentoData = DateOnly.FromDateTime(d.Value); } })" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudNumericField T="decimal" @bind-Value="newPagamentoImporto"
                                     Label="Importo €" HideSpinButtons="true" Min="0m" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="Guid" @bind-Value="newPagamentoContoId" Label="Conto" ToStringFunc="@FormatConto">
                        @foreach (var c in conti)
                        {
                            <MudSelectItem T="Guid" Value="@c.Id">@c.Codice — @c.Nome</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="2" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddPagamentoAsync"
                               Disabled="@(savingPagamento || residuo <= 0.01m)">
                        Registra
                    </MudButton>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="newPagamentoNote" Label="Note (opzionale)" />
                </MudItem>
            </MudGrid>

            @if (pagamenti.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Nessun pagamento registrato.</MudText>
            }
            else
            {
                <MudTable Items="pagamenti" Dense="true" Hover="true" Breakpoint="Breakpoint.None">
                    <HeaderContent>
                        <MudTh Style="width:110px">Data</MudTh>
                        <MudTh Style="width:130px">Importo</MudTh>
                        <MudTh>Conto</MudTh>
                        <MudTh>Note</MudTh>
                        <MudTh Style="width:50px"></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Data.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd>@FormatCurrency(context.Importo)</MudTd>
                        <MudTd>@context.ContoFinanziarioNome</MudTd>
                        <MudTd>@context.Note</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => RemovePagamentoAsync(context))" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    }

    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveAsync" Disabled="@(saving || !IsEditable)">
            Salva bozza
        </MudButton>
        @if (stato == StatoMovimento.Draft && Id.HasValue)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.CheckCircle"
                       OnClick="ConfirmAsync" Disabled="@saving">
                Conferma
            </MudButton>
        }
        @if (stato == StatoMovimento.Confirmed)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Undo"
                       OnClick="UnconfirmAsync">
                Riporta in bozza
            </MudButton>
        }
        <MudSpacer />
        @if (Id.HasValue && stato == StatoMovimento.Draft)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteAsync">
                Elimina
            </MudButton>
        }
        <MudButton Variant="Variant.Text" OnClick='() => Navigation.NavigateTo("/movimenti")'>
            Indietro
        </MudButton>
    </MudStack>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private static readonly CultureInfo ItCulture = new("it-IT");

    private MovimentoInput model = new();
    private StatoMovimento stato = StatoMovimento.Draft;
    private byte[] rowVersion = Array.Empty<byte>();
    private bool loading;
    private bool saving;

    private IReadOnlyList<CausaleDto> causali = Array.Empty<CausaleDto>();
    private IReadOnlyList<CategoriaDto> categorie = Array.Empty<CategoriaDto>();
    private IReadOnlyList<AliquotaIvaDto> aliquote = Array.Empty<AliquotaIvaDto>();
    private IReadOnlyList<ContoFinanziarioListItemDto> conti = Array.Empty<ContoFinanziarioListItemDto>();
    private IReadOnlyList<AnagraficaListItemDto> anagrafiche = Array.Empty<AnagraficaListItemDto>();
    private IReadOnlyList<AllegatoDto> allegati = Array.Empty<AllegatoDto>();
    private IReadOnlyList<PagamentoMovimentoDto> pagamenti = Array.Empty<PagamentoMovimentoDto>();

    private decimal totaleLordo;
    private decimal totalePagato;
    private decimal residuo;
    private bool isFullyPaid;
    private DateOnly? dataPagamento;

    private DateOnly newPagamentoData = DateOnly.FromDateTime(DateTime.UtcNow);
    private decimal newPagamentoImporto;
    private Guid newPagamentoContoId;
    private string? newPagamentoNote;
    private bool savingPagamento;

    private string Title => Id.HasValue ? "Modifica movimento" : "Nuovo movimento";
    private bool IsEditable => stato == StatoMovimento.Draft;
    private bool CanAddAttachment => Id.HasValue && stato != StatoMovimento.Reconciled;
    private decimal TotaleRighe => model.Righe.Sum(r => r.Importo);

    private AnagraficaRuoloFilter HeaderSuggestedRuolo
    {
        get
        {
            var causale = causali.FirstOrDefault(c => c.Id == model.CausaleId);
            return CausaleToRuolo(causale?.Tipo);
        }
    }

    private AnagraficaRuoloFilter RigaSuggestedRuolo(RigaMovimentoInput riga)
    {
        // First preference: explicit causale + category nature combined.
        var categoria = categorie.FirstOrDefault(c => c.Id == riga.CategoriaId);
        if (categoria is not null)
        {
            return categoria.Natura == NaturaCategoria.Entrata
                ? AnagraficaRuoloFilter.Clienti
                : AnagraficaRuoloFilter.Fornitori;
        }

        return HeaderSuggestedRuolo;
    }

    private static AnagraficaRuoloFilter CausaleToRuolo(TipoMovimento? tipo) => tipo switch
    {
        TipoMovimento.Incasso => AnagraficaRuoloFilter.Clienti,
        TipoMovimento.Pagamento => AnagraficaRuoloFilter.Fornitori,
        TipoMovimento.StipendioNetto => AnagraficaRuoloFilter.Dipendenti,
        TipoMovimento.RimborsoNotaSpese => AnagraficaRuoloFilter.Dipendenti,
        _ => AnagraficaRuoloFilter.Tutti,
    };

    private string FormatCausale(Guid id)
    {
        var c = causali.FirstOrDefault(x => x.Id == id);
        return c is null ? string.Empty : $"{c.Codice} — {c.Nome}";
    }

    private string FormatConto(Guid id)
    {
        var c = conti.FirstOrDefault(x => x.Id == id);
        return c is null ? string.Empty : $"{c.Codice} — {c.Nome}";
    }

    private string FormatCategoria(Guid id)
    {
        var c = categorie.FirstOrDefault(x => x.Id == id);
        return c is null ? string.Empty : $"{c.Codice} — {c.Nome}";
    }

    private string FormatAliquota(Guid? id)
    {
        if (!id.HasValue)
        {
            return string.Empty;
        }

        var a = aliquote.FirstOrDefault(x => x.Id == id.Value);
        return a is null ? string.Empty : a.Codice;
    }

    private async Task OnAnagraficaCreatedAsync(Guid newId)
    {
        anagrafiche = await Mediator.Send(new ListAnagrafiche(AnagraficaRuoloFilter.Tutti, false, null));
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            causali = await Mediator.Send(new ListCausali(false));
            categorie = await Mediator.Send(new ListCategorie(false));
            aliquote = await Mediator.Send(new ListAliquoteIva(false));
            conti = await Mediator.Send(new ListContiFinanziari(false));
            anagrafiche = await Mediator.Send(new ListAnagrafiche(AnagraficaRuoloFilter.Tutti, false, null));

            if (Id.HasValue)
            {
                var dto = await Mediator.Send(new GetMovimento(Id.Value));
                if (dto is null)
                {
                    Snackbar.Add("Movimento non trovato.", Severity.Error);
                    Navigation.NavigateTo("/movimenti");
                    return;
                }

                stato = dto.Stato;
                rowVersion = dto.RowVersion;
                allegati = dto.Allegati;
                pagamenti = dto.Pagamenti;
                totaleLordo = dto.Totale;
                totalePagato = dto.TotalePagato;
                residuo = dto.Residuo;
                isFullyPaid = dto.IsFullyPaid;
                dataPagamento = dto.DataPagamento;
                model = new MovimentoInput
                {
                    Data = dto.Data,
                    DataCompetenza = dto.DataCompetenza,
                    EsercizioAnno = dto.EsercizioAnno,
                    Descrizione = dto.Descrizione,
                    Numero = dto.Numero,
                    CausaleId = dto.CausaleId,
                    AnagraficaId = dto.AnagraficaId,
                    Note = dto.Note,
                    Righe = dto.Righe.Select(r => new RigaMovimentoInput
                    {
                        Id = r.Id,
                        Importo = r.Importo,
                        ContoFinanziarioId = r.ContoFinanziarioId,
                        CategoriaId = r.CategoriaId,
                        AnagraficaId = r.AnagraficaId,
                        AliquotaIvaId = r.AliquotaIvaId,
                        Note = r.Note,
                    }).ToList(),
                };
            }
            else
            {
                var oggi = DateOnly.FromDateTime(DateTime.UtcNow);
                model = new MovimentoInput
                {
                    Data = oggi,
                    EsercizioAnno = Esercizio.Anno,
                    Righe = new List<RigaMovimentoInput> { new() },
                };
            }
        }
        finally
        {
            loading = false;
        }
    }

    private void AddRiga()
    {
        model.Righe.Add(new RigaMovimentoInput());
    }

    private void RemoveRiga(RigaMovimentoInput riga)
    {
        model.Righe.Remove(riga);
    }

    private async Task SaveAsync()
    {
        model.EsercizioAnno = model.Data.Year;

        if (model.Righe.Count == 0)
        {
            Snackbar.Add("Aggiungi almeno una riga.", Severity.Warning);
            return;
        }

        saving = true;
        try
        {
            if (Id.HasValue)
            {
                await Mediator.Send(new UpdateMovimento(Id.Value, model, rowVersion));
                Snackbar.Add("Movimento aggiornato.", Severity.Success);
                await ReloadAsync();
            }
            else
            {
                var newId = await Mediator.Send(new CreateMovimento(model));
                Snackbar.Add("Movimento creato.", Severity.Success);
                Navigation.NavigateTo($"/movimenti/{newId}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            saving = false;
        }
    }

    private async Task ConfirmAsync()
    {
        if (!Id.HasValue) return;
        try
        {
            await Mediator.Send(new ConfirmMovimento(Id.Value, rowVersion));
            Snackbar.Add("Movimento confermato.", Severity.Success);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task UnconfirmAsync()
    {
        if (!Id.HasValue) return;
        await Mediator.Send(new UnconfirmMovimento(Id.Value, rowVersion));
        Snackbar.Add("Movimento riportato in bozza.", Severity.Info);
        await ReloadAsync();
    }

    private async Task DeleteAsync()
    {
        if (!Id.HasValue) return;
        var confirmed = await Dialog.ShowMessageBox(
            "Conferma eliminazione",
            "Eliminare il movimento in bozza? Gli allegati verranno rimossi.",
            yesText: "Elimina", cancelText: "Annulla");
        if (confirmed != true) return;

        await Mediator.Send(new DeleteMovimento(Id.Value, rowVersion));
        Snackbar.Add("Movimento eliminato.", Severity.Info);
        Navigation.NavigateTo("/movimenti");
    }

    private async Task ReloadAsync()
    {
        if (!Id.HasValue) return;
        var dto = await Mediator.Send(new GetMovimento(Id.Value));
        if (dto is null) return;
        stato = dto.Stato;
        rowVersion = dto.RowVersion;
        allegati = dto.Allegati;
        pagamenti = dto.Pagamenti;
        totaleLordo = dto.Totale;
        totalePagato = dto.TotalePagato;
        residuo = dto.Residuo;
        isFullyPaid = dto.IsFullyPaid;
        dataPagamento = dto.DataPagamento;
    }

    private async Task AddPagamentoAsync()
    {
        if (!Id.HasValue) return;
        if (newPagamentoImporto <= 0m)
        {
            Snackbar.Add("Importo del pagamento deve essere positivo.", Severity.Warning);
            return;
        }

        if (newPagamentoContoId == Guid.Empty)
        {
            Snackbar.Add("Seleziona il conto.", Severity.Warning);
            return;
        }

        savingPagamento = true;
        try
        {
            await Mediator.Send(new AddPagamentoMovimento(
                Id.Value,
                newPagamentoData,
                newPagamentoImporto,
                newPagamentoContoId,
                newPagamentoNote));
            Snackbar.Add("Pagamento registrato.", Severity.Success);
            newPagamentoImporto = 0m;
            newPagamentoNote = null;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
        finally
        {
            savingPagamento = false;
        }
    }

    private async Task RemovePagamentoAsync(PagamentoMovimentoDto p)
    {
        if (!Id.HasValue) return;
        var confirmed = await Dialog.ShowMessageBox(
            "Conferma eliminazione",
            $"Eliminare il pagamento del {p.Data:dd/MM/yyyy} di {FormatCurrency(p.Importo)}?",
            yesText: "Elimina", cancelText: "Annulla");
        if (confirmed != true) return;

        try
        {
            await Mediator.Send(new RemovePagamentoMovimento(Id.Value, p.Id));
            Snackbar.Add("Pagamento rimosso.", Severity.Info);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnAllegatoSelected(InputFileChangeEventArgs e)
    {
        if (!Id.HasValue) return;
        var file = e.File;
        if (file is null) return;

        try
        {
            // Blazor Server has direct access to the file stream, so we call the
            // MediatR handler in-process instead of round-tripping through HTTPS
            // (avoids dev-cert trust issues and is faster).
            await using var stream = file.OpenReadStream(20L * 1024 * 1024);
            await Mediator.Send(new UploadAllegato(Id.Value, file.Name, file.ContentType, stream));

            Snackbar.Add("Allegato caricato.", Severity.Success);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Errore upload: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteAllegatoAsync(AllegatoDto a)
    {
        if (!Id.HasValue) return;
        var confirmed = await Dialog.ShowMessageBox(
            "Conferma eliminazione allegato",
            $"Eliminare '{a.NomeFile}'?",
            yesText: "Elimina", cancelText: "Annulla");
        if (confirmed != true) return;

        await Mediator.Send(new DeleteAllegato(Id.Value, a.Id));
        Snackbar.Add("Allegato rimosso.", Severity.Info);
        await ReloadAsync();
    }

    private static string FormatCurrency(decimal v) => v.ToString("N2", ItCulture) + " €";

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024:N0} KB",
        _ => $"{bytes / 1024d / 1024d:N1} MB"
    };

    private static DateTime? DateOnlyToDate(DateOnly d) => d.ToDateTime(TimeOnly.MinValue);
}
